generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id           String   @id @default(uuid())
  name         String
  data         Json
  createdAt    DateTime @default(now())
  followUpSent Boolean  @default(false)
}

model Vendor {
  id                    String               @id @default(uuid())
  name                  String
  category              String
  city                  String
  basePrice             Float
  luxuryLevel           String
  autoBookingSupported  Boolean              @default(false)
  createdAt             DateTime             @default(now())
  capacity              Int?
  contactEmail          String?
  contactName           String?
  contactPhone          String?
  isActive              Boolean              @default(true)
  isFullPackageProvider Boolean              @default(false)
  notes                 String?
  pricePerPerson        Boolean              @default(true)
  serviceTypes          Json?
  isApproved            Boolean              @default(false)
  authUserId            String               @unique
  gstNumber             String?
  licenseUrl            String?
  phoneVerified         Boolean              @default(false)
  profileCompleted      Boolean              @default(false)
  inviteSent            Boolean              @default(false)
  onboardingCompleted   Boolean              @default(false)
  rating                Float                @default(4.5)
  availability          VendorAvailability[]
}

model VendorAvailability {
  id        String   @id @default(uuid())
  vendorId  String
  date      String
  available Boolean  @default(true)
  createdAt DateTime @default(now())
  vendor    Vendor   @relation(fields: [vendorId], references: [id])

  @@unique([vendorId, date])
}

model PackageTemplate {
  id             String          @id @default(uuid())
  name           String
  baseDuration   Int
  baseCity       String
  createdAt      DateTime        @default(now())
  itinerarySteps ItineraryStep[]
}

model ItineraryStep {
  id             String          @id @default(uuid())
  packageId      String
  dayNumber      Int
  activityType   String
  city           String
  vendorCategory String
  createdAt      DateTime        @default(now())
  package        PackageTemplate @relation(fields: [packageId], references: [id])
}

model BookingDraft {
  id             String   @id @default(uuid())
  userName       String?
  phone          String?
  packageName    String
  totalPrice     Float
  pricePerPerson Float
  durationDays   Int
  breakdown      Json
  createdAt      DateTime @default(now())
  bookingDate    DateTime
}

model PhoneOtp {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailOtp {
  id        String   @id @default(uuid())

  email     String
  otp       String

  expiresAt DateTime

  attempts  Int      @default(0)

  verified  Boolean  @default(false)

  createdAt DateTime @default(now())
}

model Booking {
  id              String   @id @default(uuid())
  vendorId        String
  userName        String
  phone           String
  date            DateTime
  status          String   @default("CONFIRMED")
  createdAt       DateTime @default(now())
  cancelReason    String?
  cancelRequested Boolean  @default(false)
  rejectReason    String?
}

model FeedbackRequest {
  id        String   @id @default(uuid())
  bookingId String
  status    String
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  bookingId String
  vendorId  String
  rating    Int
  comment   String
  userName  String
  createdAt DateTime @default(now())
  review    String
}

model BookingGroup {
  id                String            @id @default(uuid())
  packageName       String
  totalAmount       Float
  bookingDate       DateTime
  status            String            @default("CONFIRMED")
  leadTravelerName  String
  leadTravelerPhone String
  leadTravelerEmail String
  itinerary         Json?
  createdAt         DateTime          @default(now())
  draftId           String?
  razorpayPaymentId String?
  bookingActivities BookingActivity[]
  travelers         Traveler[]
}

model Traveler {
  id              String       @id @default(uuid())
  bookingId       String
  fullName        String
  email           String
  phone           String
  age             Int
  gender          String
  aadhaarNumber   String?
  medicalIssues   String?
  emergencyPhone  String?
  isPhysicallyFit Boolean      @default(false)
  createdAt       DateTime     @default(now())
  govIdType       String?
  govIdNumber     String?
  booking         BookingGroup @relation(fields: [bookingId], references: [id])
}

model BookingActivity {
  id           String       @id @default(uuid())
  bookingId    String
  activityName String
  activityDate DateTime
  vendorName   String
  vendorPhone  String
  vendorEmail  String
  slotTiming   String
  createdAt    DateTime     @default(now())
  booking      BookingGroup @relation(fields: [bookingId], references: [id])
}
