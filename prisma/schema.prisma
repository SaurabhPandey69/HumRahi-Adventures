generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id           String   @id @default(uuid())
  name         String
  data         Json
  createdAt    DateTime @default(now())
  followUpSent Boolean  @default(false)
}

model Vendor {
  id                    String   @id @default(uuid())

  authUserId            String   @unique

  name                  String
  category              String
  city                  String

  basePrice             Float
  rating                Float   @default(4.5) // 🔥 NEW FIELD ADDED

  pricePerPerson        Boolean  @default(true)

  serviceTypes          Json?
  isFullPackageProvider Boolean  @default(false)

  luxuryLevel           String
  capacity              Int?

  contactName           String?
  contactPhone          String?
  contactEmail          String?

  gstNumber             String?
  licenseUrl            String?
  phoneVerified         Boolean  @default(false)
  profileCompleted      Boolean  @default(false)

  inviteSent            Boolean  @default(false)
  onboardingCompleted   Boolean  @default(false)

  autoBookingSupported  Boolean  @default(false)
  isActive              Boolean  @default(true)

  isApproved            Boolean  @default(false)

  notes                 String?

  createdAt             DateTime @default(now())

  availability          VendorAvailability[]
}

model VendorAvailability {
  id        String   @id @default(uuid())
  vendorId  String

  // 🔥 FIXED (NO TIMEZONE BUG)
  date      String   // ✅ YYYY-MM-DD format

  available Boolean  @default(true)

  vendor Vendor @relation(fields: [vendorId], references: [id])

  createdAt DateTime @default(now())

  // 🔥 STILL SAFE (string unique)
  @@unique([vendorId, date])
}

model PackageTemplate {
  id           String   @id @default(uuid())
  name         String
  baseDuration Int
  baseCity     String
  createdAt    DateTime @default(now())

  itinerarySteps ItineraryStep[]
}

model ItineraryStep {
  id             String   @id @default(uuid())
  packageId      String
  dayNumber      Int
  activityType   String
  city           String
  vendorCategory String

  package PackageTemplate @relation(fields: [packageId], references: [id])

  createdAt DateTime @default(now())
}

model BookingDraft {
  id             String   @id @default(uuid())
  userName       String?
  phone          String?
  packageName    String
  totalPrice     Float
  pricePerPerson Float
  durationDays   Int
  breakdown      Json

  bookingDate    DateTime

  createdAt      DateTime @default(now())
}

model PhoneOtp {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

//
// 🔥 NEW MODEL (BOOKING SYSTEM)
//
model Booking {
  id        String   @id @default(uuid())
  vendorId  String
  userName  String
  phone     String
  date      DateTime
  status    String   @default("CONFIRMED")
  cancelReason String?
  cancelRequested Boolean @default(false)
  rejectReason    String?   // 🔥 REQUIRED
  createdAt DateTime @default(now())
}

model FeedbackRequest {
  id        String   @id @default(uuid())
  bookingId String
  status    String   // PENDING / SUBMITTED
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  bookingId String
  vendorId  String
  rating    Int
  review    String
  comment   String
  userName  String
  createdAt DateTime @default(now())
}